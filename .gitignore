# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# ── Laravel backend (baderna-api) ──────────────────────────
baderna-api/vendor/
baderna-api/node_modules/
baderna-api/.env
baderna-api/.env.backup
baderna-api/.env.production
baderna-api/storage/*.key
baderna-api/storage/app/public/*
!baderna-api/storage/app/public/.gitkeep
baderna-api/storage/framework/cache/*
baderna-api/storage/framework/sessions/*
baderna-api/storage/framework/views/*
baderna-api/storage/logs/*
!baderna-api/storage/**/.gitkeep
baderna-api/bootstrap/cache/*.php
baderna-api/database/database.sqlite


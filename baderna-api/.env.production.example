# =============================================================================
# .env de PRODUÇÃO — Laravel (Hostinger)
# Copia este arquivo pra `.env` na pasta da Hostinger e preenche os valores.
# =============================================================================

APP_NAME=Baderna
APP_ENV=production
APP_KEY=                      # Gera com: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://api.bdrn.com.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR
APP_MAINTENANCE_DRIVER=file

# --- Logs (Hostinger não usa stderr; salva em arquivo) -----------------------
LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Banco MySQL da Hostinger ------------------------------------------------
# Pega esses dados no painel: Bancos de dados → MySQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=u<seu_id>_baderna
DB_USERNAME=u<seu_id>_baderna
DB_PASSWORD=

# --- Sessions / Cache / Queue em DB (não usa Redis em shared) ----------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- Frontend / CORS ---------------------------------------------------------
# Lido por config/cors.php — adiciona o domínio do site
FRONTEND_URL=https://bdrn.com.br

# Sanctum opera por Bearer Token; não precisa de STATEFUL_DOMAINS pra esse fluxo.

# --- Riot API ----------------------------------------------------------------
RIOT_API_KEY=RGAPI-                # Production key da Riot
RIOT_REGION=br1                    # ou as ROUTING regions usadas
